# Sanity — variables requises pour démarrer le projet.
# Récupère le Project ID sur https://www.sanity.io/manage
# Copie ce fichier en `.env.local` et renseigne les valeurs.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optionnel — un défaut est défini dans sanity/env.ts
NEXT_PUBLIC_SANITY_API_VERSION=2025-10-14
