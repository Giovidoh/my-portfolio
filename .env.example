# Sanity — variables requises pour démarrer le projet.
# Récupère le Project ID sur https://www.sanity.io/manage
# Copie ce fichier en `.env.local` et renseigne les valeurs.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optionnel — un défaut est défini dans sanity/env.ts
NEXT_PUBLIC_SANITY_API_VERSION=2025-10-14

# Formulaire de contact (Resend) — https://resend.com/api-keys
# Sans ces variables, le formulaire renvoie une erreur "non configuré".
RESEND_API_KEY=
CONTACT_TO_EMAIL=          # adresse qui reçoit les messages (ex. ton e-mail)
# Optionnel : expéditeur. Par défaut "Portfolio <onboarding@resend.dev>" (domaine de test Resend).
# En prod, vérifie ton domaine sur Resend et mets ex. "Portfolio <hello@tondomaine.dev>".
CONTACT_FROM_EMAIL=
